{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "server/dist",
    "rootDir": ".",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"]
  },
  "include": ["server/src/**/*.ts", "src/core/protocol/**/*.ts", "src/core/document/**/*.ts", "src/core/profile/**/*.ts"],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
